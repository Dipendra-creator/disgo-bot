# disgo-bot environment overrides.
#
# Copy to .env and fill in. docker-compose reads this file automatically; for
# local `go run` use a tool like direnv or `set -a; . ./.env; set +a`.
# Env vars override any value in config.yaml.

# --- Core ---
DISGO_ENV=development

# --- Discord (required) ---
DISCORD_TOKEN=
DISCORD_APP_ID=
# Guild-scoped command registration for instant dev updates. Empty = global.
DISCORD_DEV_GUILD_ID=
# Enable the GuildMembers + MessageContent privileged intents (needed for
# member join/leave and message-content logging). Must ALSO be enabled in the
# Discord developer portal, or the gateway refuses to connect.
DISCORD_PRIVILEGED_INTENTS=false

# --- Postgres ---
# A full URL takes precedence over the POSTGRES_* parts.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/disgo?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=disgo

# --- Redis (optional; in-memory fallback when disabled) ---
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=console

# --- Sentry (optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=

# --- Web dashboard (optional; disabled by default) ---
# When enabled, serves a browser dashboard with Discord OAuth2 login so admins
# can configure modules. Add ${WEB_PUBLIC_URL}/auth/callback as a redirect URI
# in the Discord developer portal. ClientID reuses DISCORD_APP_ID.
WEB_ENABLED=false
WEB_ADDR=:8081
# Public base URL the dashboard is reached at (used to build the OAuth redirect).
WEB_PUBLIC_URL=
# OAuth2 client secret from the Discord developer portal (never logged).
DISCORD_CLIENT_SECRET=
# Set true when served over HTTPS so the session cookie carries the Secure flag.
WEB_COOKIE_SECURE=false
# Session lifetime in hours (default 168 = 7 days).
WEB_SESSION_HOURS=168
