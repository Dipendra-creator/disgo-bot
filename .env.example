# disgo-bot environment overrides.
#
# Copy to .env and fill in. docker-compose reads this file automatically; for
# local `go run` use a tool like direnv or `set -a; . ./.env; set +a`.
# Env vars override any value in config.yaml.

# --- Core ---
DISGO_ENV=development

# --- Discord (required) ---
DISCORD_TOKEN=
DISCORD_APP_ID=
# Guild-scoped command registration for instant dev updates. Empty = global.
DISCORD_DEV_GUILD_ID=

# --- Postgres ---
# A full URL takes precedence over the POSTGRES_* parts.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/disgo?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=disgo

# --- Redis (optional; in-memory fallback when disabled) ---
REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=console

# --- Sentry (optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=
