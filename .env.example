# disgo-bot deployment config.
#
#   cp .env.example .env
#   nano .env            # fill the values below
#   sudo ./setup.sh      # reads ./.env, installs everything, no prompts
#
# Lines are KEY=value. No spaces around '='. Quote values only if they
# contain spaces. The installer strips Windows CR and surrounding quotes,
# so a file edited on Windows is fine.

# ── Discord (required) ───────────────────────────────────────────────
# From the Discord Developer Portal → your application.
DISCORD_APP_ID=
DISCORD_TOKEN=
# Optional: register slash-commands instantly in one guild during testing.
# Leave blank in production to register globally (can take up to 1h).
DISCORD_DEV_GUILD_ID=
# Enable members + message-content gateway intents. Must ALSO be toggled on
# in the portal (Bot → Privileged Gateway Intents), or the bot fails to start.
DISCORD_PRIVILEGED_INTENTS=false

# ── Database ─────────────────────────────────────────────────────────
# Option A — let the installer provision a local PostgreSQL on this VM:
#   leave DATABASE_URL blank, keep PG_INSTALL=true.
# Option B — use an existing/managed PostgreSQL (e.g. AWS RDS):
#   set DATABASE_URL, set PG_INSTALL=false.
DATABASE_URL=
PG_INSTALL=true
PG_DB=disgo
PG_USER=disgo
# Blank = auto-generate a strong password (recommended).
PG_PASSWORD=

# ── Web dashboard ────────────────────────────────────────────────────
WEB_ENABLED=true
WEB_ADDR=:8081
# Externally reachable base URL the OAuth redirect is built from.
# Blank = auto-detect this VM's public IP → http://<ip><WEB_ADDR>.
# After install, register  <WEB_PUBLIC_URL>/auth/callback  in the portal.
WEB_PUBLIC_URL=
# true only when WEB_PUBLIC_URL is https:// (behind a TLS proxy / ALB).
WEB_COOKIE_SECURE=false
# Discord OAuth2 client secret (required when WEB_ENABLED=true).
DISCORD_CLIENT_SECRET=

# ── AI assistant module (optional) ───────────────────────────────────
AI_ENABLED=false
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# ── Runtime ──────────────────────────────────────────────────────────
DISGO_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json
